# ============================================================================
# DocuMind — Environment Variable Template
# ============================================================================
# Copy this file to `.env` and fill in values. NEVER commit `.env`.
#
# Convention: every service reads its own prefix (e.g. INGESTION_*, RETRIEVAL_*)
# plus the shared DOCUMIND_* variables. This lets you run services standalone
# and lets Docker Compose / K8s ConfigMaps inject per-service overrides.
# ============================================================================

# ---------------------------------------------------------------
# Environment + logging
# ---------------------------------------------------------------
DOCUMIND_ENV=development              # development | staging | production
DOCUMIND_LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
DOCUMIND_LOG_JSON=true                # structured JSON logs (set false for human dev)
DOCUMIND_REGION=local                 # local | us-east-1 | eu-west-1 …

# ---------------------------------------------------------------
# Security
# ---------------------------------------------------------------
# JWT signing — RS256. For dev, use the stub keys in scripts/dev-keys/.
# NEVER use the dev keys in production.
DOCUMIND_JWT_PRIVATE_KEY_PATH=./scripts/dev-keys/jwt-private.pem
DOCUMIND_JWT_PUBLIC_KEY_PATH=./scripts/dev-keys/jwt-public.pem
DOCUMIND_JWT_ISSUER=documind-local
DOCUMIND_JWT_AUDIENCE=documind-services
DOCUMIND_JWT_ACCESS_TTL=900           # 15 minutes
DOCUMIND_JWT_REFRESH_TTL=604800       # 7 days

# Fernet symmetric encryption for at-rest secrets (API keys, webhooks, etc.)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
DOCUMIND_ENCRYPTION_KEY=

# API key for admin endpoints (bypasses JWT — dev/CI only)
DOCUMIND_ADMIN_API_KEY=change-me-in-production

# CORS origins (comma-separated, no wildcards in production)
DOCUMIND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ---------------------------------------------------------------
# Data stores
# ---------------------------------------------------------------
# PostgreSQL (shared across services, schema-per-service)
DOCUMIND_PG_HOST=localhost
DOCUMIND_PG_PORT=5432
DOCUMIND_PG_DB=documind
DOCUMIND_PG_USER=documind
DOCUMIND_PG_PASSWORD=documind
DOCUMIND_PG_MAX_CONNS=20
DOCUMIND_PG_MIN_CONNS=2

# Redis
DOCUMIND_REDIS_URL=redis://localhost:6379/0
DOCUMIND_REDIS_POOL_SIZE=20

# Qdrant (vector DB)
DOCUMIND_QDRANT_URL=http://localhost:6333
DOCUMIND_QDRANT_API_KEY=
DOCUMIND_QDRANT_COLLECTION=chunks

# Neo4j (graph DB)
DOCUMIND_NEO4J_URI=bolt://localhost:7687
DOCUMIND_NEO4J_USER=neo4j
DOCUMIND_NEO4J_PASSWORD=documind

# Kafka
DOCUMIND_KAFKA_BOOTSTRAP=localhost:9092
DOCUMIND_KAFKA_CLIENT_ID=documind
DOCUMIND_KAFKA_CONSUMER_GROUP_PREFIX=documind-

# MinIO (S3-compatible object store)
DOCUMIND_MINIO_ENDPOINT=localhost:9000
DOCUMIND_MINIO_ACCESS_KEY=documind
DOCUMIND_MINIO_SECRET_KEY=documind-secret
DOCUMIND_MINIO_BUCKET=documents
DOCUMIND_MINIO_USE_SSL=false

# ---------------------------------------------------------------
# LLM / Embedding providers
# ---------------------------------------------------------------
DOCUMIND_OLLAMA_URL=http://localhost:11434
DOCUMIND_OLLAMA_LLM_MODEL=llama3.1:8b
DOCUMIND_OLLAMA_EMBED_MODEL=nomic-embed-text
DOCUMIND_OLLAMA_TIMEOUT_SECONDS=60

# Optional cloud fallback (leave blank to disable)
OPENAI_API_KEY=

# ---------------------------------------------------------------
# Observability
# ---------------------------------------------------------------
DOCUMIND_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
DOCUMIND_OTEL_SERVICE_NAMESPACE=documind
DOCUMIND_PROMETHEUS_PORT=9464

# ---------------------------------------------------------------
# Service ports (mirror spec §2.3)
# ---------------------------------------------------------------
API_GATEWAY_HTTP_PORT=8080
API_GATEWAY_GRPC_PORT=9090

IDENTITY_HTTP_PORT=8081
IDENTITY_GRPC_PORT=9091

INGESTION_HTTP_PORT=8082
INGESTION_GRPC_PORT=9092

RETRIEVAL_HTTP_PORT=8083
RETRIEVAL_GRPC_PORT=9093

INFERENCE_HTTP_PORT=8084
INFERENCE_GRPC_PORT=9094

EVALUATION_HTTP_PORT=8085
EVALUATION_GRPC_PORT=9095

GOVERNANCE_HTTP_PORT=8086
GOVERNANCE_GRPC_PORT=9096

FINOPS_HTTP_PORT=8087
FINOPS_GRPC_PORT=9097

OBSERVABILITY_HTTP_PORT=8088
OBSERVABILITY_GRPC_PORT=9098

FRONTEND_PORT=3000

# ---------------------------------------------------------------
# Rate limiting (per-tenant defaults; overridden by governance service)
# ---------------------------------------------------------------
DOCUMIND_RATE_LIMIT_API_PER_MIN=100
DOCUMIND_RATE_LIMIT_UPLOAD_PER_MIN=10
DOCUMIND_RATE_LIMIT_ADMIN_PER_MIN=50
DOCUMIND_RATE_LIMIT_INFERENCE_PER_MIN=20

# ---------------------------------------------------------------
# Chunking / Retrieval defaults (tenant-overridable)
# ---------------------------------------------------------------
DOCUMIND_CHUNK_SIZE=512
DOCUMIND_CHUNK_OVERLAP=50
DOCUMIND_RETRIEVAL_TOP_K=10
DOCUMIND_RERANK_TOP_K=5
DOCUMIND_MAX_CONTEXT_TOKENS=4000
