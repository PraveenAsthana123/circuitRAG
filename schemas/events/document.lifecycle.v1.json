{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "document.lifecycle.v1",
  "description": "CloudEvents envelope for document-lifecycle events (uploaded, parsed, chunked, embedded, indexed, deleted).",
  "type": "object",
  "required": ["id", "source", "type", "specversion", "time", "tenantid", "data"],
  "properties": {
    "id":            { "type": "string", "format": "uuid" },
    "source":        { "type": "string" },
    "type":          { "type": "string",
                       "enum": ["document.uploaded.v1", "document.parsed.v1",
                                "document.chunked.v1", "document.embedded.v1",
                                "document.indexed.v1", "document.deleted.v1"] },
    "specversion":   { "type": "string", "const": "1.0" },
    "time":          { "type": "string", "format": "date-time" },
    "tenantid":      { "type": "string", "format": "uuid" },
    "correlationid": { "type": "string" },
    "subject":       { "type": "string", "description": "document_id" },
    "data": {
      "type": "object",
      "properties": {
        "document_id":     { "type": "string", "format": "uuid" },
        "filename":        { "type": "string" },
        "page_count":      { "type": "integer", "minimum": 0 },
        "chunk_count":     { "type": "integer", "minimum": 0 },
        "embedding_model": { "type": "string" },
        "processing_time_ms": { "type": "integer", "minimum": 0 }
      },
      "required": ["document_id"]
    }
  }
}
