{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "audit.events.v1",
  "description": "CloudEvents envelope for auditable state changes.",
  "type": "object",
  "required": ["id", "source", "type", "time", "tenantid", "data"],
  "properties": {
    "id":            { "type": "string", "format": "uuid" },
    "source":        { "type": "string" },
    "type":          { "type": "string", "pattern": "^audit\\..+\\.v\\d+$" },
    "specversion":   { "type": "string", "const": "1.0" },
    "time":          { "type": "string", "format": "date-time" },
    "tenantid":      { "type": "string", "format": "uuid" },
    "correlationid": { "type": "string" },
    "data": {
      "type": "object",
      "required": ["action", "actor_type"],
      "properties": {
        "action":        { "type": "string" },
        "actor_id":      { "type": "string" },
        "actor_type":    { "type": "string",
                           "enum": ["user", "system", "admin", "service"] },
        "resource_type": { "type": "string" },
        "resource_id":   { "type": "string" },
        "details":       { "type": "object" }
      }
    }
  }
}
